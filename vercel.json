{
  "rewrites": [
    { "source": "/", "destination": "/toolkit/index.html" },
    { "source": "/investor-deck", "destination": "/investor-deck/index.html" },
    { "source": "/brochure", "destination": "/brochure/index.html" },
    { "source": "/partner-prospectus", "destination": "/partner-prospectus/index.html" },
    { "source": "/website", "destination": "/website/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
